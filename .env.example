# Database (Neon PostgreSQL recommended for Vercel)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
AUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Direct DB connection for Prisma migrations (Neon)
# DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# Vercel Blob — voor bestandsopslag (bijlagen)
# Maak een Blob store aan in Vercel Dashboard → Storage → Create Blob Store
# Kopieer de BLOB_READ_WRITE_TOKEN uit de instellingen van de Blob store.
# Zonder dit token worden bijlagen als base64 in de database opgeslagen (legacy).
BLOB_READ_WRITE_TOKEN=""

# E-mail (SMTP) — voor gebruikersuitnodigingen
# Laat leeg om e-mailverzending uit te schakelen.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="TAAS <noreply@example.com>"

# Logging — debug | info | warn | error (default: info in production, debug in dev)
LOG_LEVEL="info"

# Seed accounts — optional. If unset, strong random passwords are generated and
# must be reset via the set-password flow. Demo seeding is blocked in production
# unless ALLOW_PROD_SEED=true.
SEED_SUPERADMIN_PASSWORD=""
SEED_TENANTADMIN_PASSWORD=""
SEED_TESTER_PASSWORD=""
SEED_MANAGER_PASSWORD=""
# ALLOW_PROD_SEED="false"
